rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.uid == 'H4SpFj8353NqCh51PqsuBMvcufs1';
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // Posts — public read (published only), contributor/admin write
    match /posts/{postId} {
      allow read: if resource.data.published == true || isAdmin()
        || (isAuthenticated() && request.auth.uid == resource.data.authorUid);
      allow write: if isAdmin()
        || (isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['contributor']);
    }

    // Comments — public read, authenticated write, admin delete
    match /comments/{postSlug}/entries/{entryId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAdmin()
        || (isAuthenticated() && request.auth.uid == resource.data.authorUid);
    }

    // Users — own read/write, admin read all
    match /users/{uid} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == uid);
      allow write: if isAdmin() || (isAuthenticated() && request.auth.uid == uid);
    }

    // Invites — admin only
    match /invites/{email} {
      allow read, write: if isAdmin();
    }

    // Category config — public read, admin write
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Family app — families, tasks, events
    function isInFamily(familyId) {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId == familyId;
    }

    match /families/{familyId} {
      allow read, update: if isInFamily(familyId);
      allow create: if request.auth != null
        && request.resource.data.members[0].uid == request.auth.uid;

      match /tasks/{taskId} {
        allow read, write: if isInFamily(familyId);
      }

      match /events/{eventId} {
        allow read, write: if isInFamily(familyId);
      }
    }
  }
}
