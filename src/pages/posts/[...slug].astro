---
import Base from '../../layouts/Base.astro';
import Comments from '../../components/Comments';
import RouteMap from '../../components/travel/RouteMap';
import '../../styles/stream.css';
import '../../styles/comments.css';
import '../../styles/travel.css';
import { MASTODON_INSTANCE, MASTODON_USERNAME } from '../../config';
import { getAdminDb } from '../../lib/firebase-admin';

const { slug } = Astro.params;

if (!slug) return Astro.redirect('/');

const db = getAdminDb();
const docSnap = await db.collection('posts').doc(slug).get();

if (!docSnap.exists) return new Response(null, { status: 404 });

const post = docSnap.data()!;

if (!post.published) return new Response(null, { status: 404 });

const postDate = post.createdAt?.toDate?.() ?? new Date();

function formatDate(d: Date) {
  return d.toLocaleDateString('en-AU', { year: 'numeric', month: 'long', day: 'numeric' });
}

function stripHtml(html: string) {
  return html.replace(/<[^>]+>/g, '').trim();
}

// Fetch route if linked
let routeCoords: Array<{ lat: number; lng: number }> | null = null;
if (post.routeId) {
  try {
    const routeSnap = await db.collection('routes').doc(post.routeId).get();
    if (routeSnap.exists) {
      routeCoords = (routeSnap.data() as any).coordinates ?? null;
    }
  } catch {
    // silently skip
  }
}

// Fetch trip-linked Mastodon posts if mastodon_tag is set
let tripPosts: any[] = [];
if (post.mastodon_tag) {
  try {
    const accountRes = await fetch(
      `https://${MASTODON_INSTANCE}/api/v1/accounts/lookup?acct=${MASTODON_USERNAME}`
    );
    if (accountRes.ok) {
      const account = await accountRes.json();
      const res = await fetch(
        `https://${MASTODON_INSTANCE}/api/v1/accounts/${account.id}/statuses?tagged=${post.mastodon_tag}&limit=40&exclude_replies=true&exclude_reblogs=true`
      );
      if (res.ok) tripPosts = await res.json();
    }
  } catch {
    // silently skip
  }
}
---

<Base
  title={post.title}
  description={(post.excerpt ?? stripHtml(post.content).slice(0, 160)) || undefined}
  ogType="article"
>
  <article>
    <header class="post-header">
      <time class="post-date">{formatDate(postDate)}</time>
      <h1 class="post-title">{post.title}</h1>
    </header>

    {routeCoords && routeCoords.length >= 2 && (
      <div class="post-route">
        <RouteMap coordinates={routeCoords} client:load />
      </div>
    )}

    <div class="prose" set:html={post.content} />
  </article>

  <Comments postSlug={slug} client:load />

  {tripPosts.length > 0 && (
    <aside class="trip-stream">
      <h2 class="trip-stream__heading">From the road</h2>
      <div class="stream">
        {tripPosts.map((s) => (
          <article class="entry entry--mastodon">
            <time class="entry-date" datetime={s.created_at}>
              {formatDate(new Date(s.created_at))}
            </time>
            <p class="mastodon-text" set:html={s.content} />
            {s.media_attachments?.filter((m: any) => m.type === 'image').length > 0 && (
              <div class="entry-media">
                {s.media_attachments
                  .filter((m: any) => m.type === 'image')
                  .map((m: any) => (
                    <img src={m.url} alt={m.description ?? ''} loading="lazy" />
                  ))}
              </div>
            )}
          </article>
        ))}
      </div>
    </aside>
  )}
</Base>

<style>
  .post-route {
    margin-bottom: 2.5rem;
  }

  .post-header {
    margin-bottom: 2.5rem;
  }

  .post-date {
    display: block;
    font-size: 0.8rem;
    color: var(--color-accent);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 0.6rem;
    font-family: var(--font-ui);
  }

  .post-title {
    font-family: var(--font-ui);
    font-size: 1.9rem;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .trip-stream {
    margin-top: 5rem;
    padding-top: 3rem;
    border-top: 1px solid var(--color-divider);
  }

  .trip-stream__heading {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 2rem;
  }
</style>
