---
import Base from '../layouts/Base.astro';
import LifeStream from '../components/LifeStream';
import '../styles/stream.css';
---

<Base>
  <div class="hero">
    <h1 class="wordmark">out of<br><span>breathed<em>.</em></span></h1>
    <p class="tagline">A personal stream.</p>
    <div class="hero-rule">
      <div class="rule-accent"></div>
      <div class="rule-line"></div>
    </div>
  </div>
  <LifeStream client:load />
</Base>

<style>
  .hero {
    padding: 2rem 0 2.5rem;
  }

  .wordmark {
    font-size: 3.75rem;
    font-weight: 300;
    color: var(--color-text);
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 1.25rem;
  }

  .wordmark span {
    color: var(--color-accent);
  }

  .wordmark em {
    font-style: normal;
    color: var(--color-accent);
  }

  .tagline {
    font-size: 0.95rem;
    font-weight: 300;
    color: #3d3b39;
    letter-spacing: -0.01em;
    margin-bottom: 2rem;
  }

  .hero-rule {
    display: flex;
    align-items: center;
  }

  .rule-accent {
    height: 2px;
    width: 40px;
    background: var(--color-accent);
    flex-shrink: 0;
  }

  .rule-line {
    height: 1px;
    flex: 1;
    background: var(--color-divider);
  }
</style>
