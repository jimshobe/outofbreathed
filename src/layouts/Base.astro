---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'outofbreathed.com',
  description = 'A personal stream.',
} = Astro.props;

const fullTitle = title === 'outofbreathed.com' ? title : `${title} — outofbreathed.com`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="layout">
      <header>
        <nav>
          <a href="/" class="site-name">outofbreathed.com</a>
          <div class="nav-links">
            <a href="/about" aria-label="About" class="nav-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="8" r="4"/>
                <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
              </svg>
            </a>
          </div>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer>
      </footer>
    </div>
  </body>
</html>

<style>
  .layout {
    max-width: var(--width-content);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  header {
    padding: 2.5rem 0 3rem;
  }

  nav {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }

  .site-name {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  .site-name:hover {
    color: var(--color-text);
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
  }

  .nav-icon {
    display: flex;
    align-items: center;
    color: var(--color-muted);
  }

  .nav-icon:hover {
    color: var(--color-text);
  }

  main {
    padding-bottom: 6rem;
  }

  footer {
    padding: 2rem 0 3rem;
    border-top: 1px solid var(--color-divider);
    font-size: 0.85rem;
    color: var(--color-muted);
  }
</style>
