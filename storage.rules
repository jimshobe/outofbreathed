rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Post images — any signed-in user can upload, public can read
    match /posts/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Travel media — admin only
    match /travel/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == 'H4SpFj8353NqCh51PqsuBMvcufs1';
    }

    // GPX routes — admin only
    match /routes/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == 'H4SpFj8353NqCh51PqsuBMvcufs1';
    }
  }
}
